# Mining Tracker - Environment Variables
# Copy this to .env and customize

# App Configuration
VITE_APP_TITLE=Mining Tracker
VITE_APP_VERSION=1.0.0

# Default currency (USD, EUR, IDR, etc.)
VITE_DEFAULT_CURRENCY=USD

# Default locale (en-US, id-ID, etc.)
VITE_DEFAULT_LOCALE=en-US

# Enable particle background (true/false)
VITE_PARTICLES_ENABLED=true

# Particle density (1-100)
VITE_PARTICLE_DENSITY=50